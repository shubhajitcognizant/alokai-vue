{
  "extends": [
    "stylelint-config-standard",
    "stylelint-config-recommended-vue"
  ],
  "rules": {
    "at-rule-no-unknown": [true, {
      "ignoreAtRules": ["plugin", "source", "theme", "utility", "variant"]
    }],
    "import-notation": "string"
  },
  "ignoreFiles": [
    "**/dist/**",
    "**/node_modules/**"
  ]
}
