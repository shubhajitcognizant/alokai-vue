{
  "name": "alokai-vue-monorepo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "apps/storefront",
    "apps/storefront-middleware"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "dev:middleware": "npm run dev --workspace=apps/storefront-middleware",
    "lint": "eslint \"apps/**/*.{ts,vue}\"",
    "lint:fix": "eslint \"apps/**/*.{ts,vue}\" --fix",
    "stylelint": "stylelint \"apps/**/*.{css,vue}\"",
    "stylelint:fix": "stylelint \"apps/**/*.{css,vue}\" --fix",
    "prepare": "husky",
    "cleancode:fix": "eslint \"apps/**/*.{ts,vue}\" --fix && stylelint \"apps/**/*.{css,vue}\" --fix"
  },
  "dependencies": {
    "firebase": "^11.0.0",
    "vue": "^3.5.30",
    "vue-router": "^5.0.4",
    "vue3-carousel": "^0.17.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@storefront-ui/typography": "^3.1.0",
    "@storefront-ui/vue": "^3.1.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.0",
    "eslint": "^10.1.0",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "stylelint": "^17.6.0",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-config-standard": "^40.0.0",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "vite": "^8.0.1",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.5"
  }
}
